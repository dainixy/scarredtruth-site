# Scarred Truth backend — environment variables.
# Copy to .env for local live testing (.env is gitignored). On Render these are set
# in the dashboard. With NO OPENROUTER_API_KEY (or ZANE_MOCK=1) the app runs in
# deterministic mock mode, so local dev needs none of these.

# --- AI (OpenRouter -> DeepSeek) ---
OPENROUTER_API_KEY=                       # required to go live; empty = mock mode
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v3.2
OPENROUTER_NOTE_MODEL=                    # optional; defaults to the chat model
OPENROUTER_REFERER=https://scarredtruth.com

# --- Storage ---
STORE_BACKEND=                            # empty/"json" = local JSON files; "supabase" = prod
SUPABASE_URL=                             # required when STORE_BACKEND=supabase
SUPABASE_SERVICE_KEY=                     # service_role key (server-only, never client)

# --- App ---
PORT=5178
NODE_ENV=development
FREE_CHAT_CAP=50
ALLOWED_ORIGINS=                          # CSV of allowed origins in prod, e.g. https://scarredtruth.com,https://www.scarredtruth.com

# --- Local mock toggle ---
ZANE_MOCK=                                # set to 1 to force mock mode even with a key
